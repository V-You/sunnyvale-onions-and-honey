# Evervault
EV_API_KEY=ev:key:xxx
EV_APP_ID=app_83ec49c3a3f6
NEXT_PUBLIC_EVERVAULT_APP_ID=app_83ec49c3a3f6
NEXT_PUBLIC_EVERVAULT_TEAM_ID=team_756b84cdd4ff

# PSP switching, possible values:
# aci
# stripe
ACTIVE_PSP=aci

# ACP auth
# `ACP_API_KEYS` is a comma-separated allowlist for server-side bearer validation.
# `NEXT_PUBLIC_ACP_API_KEY` is the demo browser key used by the human checkout flow.
ACP_API_KEYS=sunnyvale-demo-acp-key
NEXT_PUBLIC_ACP_API_KEY=sunnyvale-demo-acp-key

# Relay domains (from Evervault relay creation output)
ACI_RELAY_DOMAIN=eu-test-oppwa-com-app-83ec49c3a3f6.relay.evervault.app
STRIPE_RELAY_DOMAIN=api.stripe.com.relay.evervault.app

# ACI Worldwide (UAT)
ACI_ENTITY_ID=8a8294174b7ecb28014b9699220015ca
ACI_TOKEN=OGE4Mjk0MTc0YjdlY2IyODAxNGI5Njk5MjIwMDE1Y2F8...

# Stripe (test mode)
STRIPE_PUBLISHABLE_KEY=pk_test_yyyy
STRIPE_SECRET_KEY=sk_test_xxx

# TinaCMS (if using TinaCloud)
NEXT_PUBLIC_TINA_CLIENT_ID=xxx
TINA_CLIENT_ID=xxx
TINA_TOKEN=xxx

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://sunnyvale-onions-and-honey.pages.dev
