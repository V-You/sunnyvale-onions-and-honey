{
  "name": "sunnyvale-onions-and-honey",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "catalog:generate": "node scripts/sync-products.mjs",
    "admin:build": "npm run catalog:generate && npx @tinacms/cli build --local --datalayer-port 9010 --skip-cloud-checks",
    "dev": "npm run catalog:generate && next dev",
    "build": "npm run catalog:generate && npm run admin:build && next build",
    "start": "npm run catalog:generate && next start",
    "lint": "next lint",
    "pages:build": "npm run build && npx @cloudflare/next-on-pages@1"
  },
  "dependencies": {
    "@evervault/react": "^2.0.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tinacms": "^3.6.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260101.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tinacms/cli": "^2.1.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
